# =============================================================================
# GridTokenX Explorer — Environment Configuration (example)
# =============================================================================
# Copy to `.env` (or `.env.local`) and fill in values for your environment.
# Vars prefixed NEXT_PUBLIC_ are exposed to the browser; all others are
# server-side only. Empty value = fall back to the documented default.
# Every var below is read by the code; "default" is the in-code fallback.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
## Public base URL (metadata origin / canonical). REQUIRED (validateEnvConfig).
## Default: https://explorer.gridtokenx.com
NEXT_PUBLIC_URL=http://localhost:3000

## Node environment: development | production | test (set by tooling)
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Solana RPC — client-side (browser)
# -----------------------------------------------------------------------------
## Active HTTP RPC for the selected cluster. Mainnet fallback if unset:
## https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_HTTP=http://localhost:8899
## WebSocket RPC (realtime). Default: derived/none
NEXT_PUBLIC_SOLANA_RPC_WS=ws://localhost:8900

## Default cluster on startup: mainnet-beta | testnet | devnet | localnet | custom
## Default: mainnet-beta
NEXT_PUBLIC_DEFAULT_CLUSTER=localnet

## Per-cluster RPC overrides (empty = public Solana endpoint for that cluster)
NEXT_PUBLIC_MAINNET_RPC_URL=
NEXT_PUBLIC_DEVNET_RPC_URL=
NEXT_PUBLIC_TESTNET_RPC_URL=
NEXT_PUBLIC_LOCALNET_RPC_URL=http://localhost:8899

# -----------------------------------------------------------------------------
# Solana RPC — server-side overrides (non-public, take precedence on the server)
# -----------------------------------------------------------------------------
# SOLANA_RPC_HTTP=
# MAINNET_RPC_URL=
# DEVNET_RPC_URL=
# TESTNET_RPC_URL=
# LOCALNET_RPC_URL=

# -----------------------------------------------------------------------------
# GridTokenX Program IDs
# Must match the programs deployed to the active cluster. Each has an in-code
# default; set explicitly to override per-deployment.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_REGISTRY_PROGRAM_ID=
NEXT_PUBLIC_ORACLE_PROGRAM_ID=
NEXT_PUBLIC_GOVERNANCE_PROGRAM_ID=
NEXT_PUBLIC_TOKEN_PROGRAM_ID=
NEXT_PUBLIC_TRADING_PROGRAM_ID=
NEXT_PUBLIC_TREASURY_PROGRAM_ID=
## Blockbench TPC-C benchmarking program (optional)
NEXT_PUBLIC_BLOCKBENCH_PROGRAM_ID=

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
## GridTokenX trading API base URL. Default: http://localhost:8080
NEXT_PUBLIC_API_URL=http://gridtokenx-apisix.orb.local:9080

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
## Allow users to enter a custom RPC URL. Default: false (dev override: true)
NEXT_PUBLIC_ENABLE_CUSTOM_RPC=false
## Enable analytics collection. Default: false (prod override: true)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
## Enable experimental/beta feature gates. Default: true (set 'false' to disable)
NEXT_PUBLIC_ENABLE_FEATURE_GATES=true
## Disable token search (token-list API). Default: enabled
NEXT_PUBLIC_DISABLE_TOKEN_SEARCH=
## Show "VIEW ORIGINAL" link on cNFT metadata. Default: false
NEXT_PUBLIC_VIEW_ORIGINAL_DISPLAY_ENABLED=

# -----------------------------------------------------------------------------
# Program Metadata Program (PMP)
# -----------------------------------------------------------------------------
## Enable IDL retrieval via PMP. Default: false
NEXT_PUBLIC_PMP_IDL_ENABLED=true
## Enable security.txt retrieval via PMP. Default: false
NEXT_PUBLIC_PMP_SECURITY_TXT_ENABLED=true

# -----------------------------------------------------------------------------
# Metadata proxy service
# -----------------------------------------------------------------------------
## Enable the metadata proxy (blocks private-IP fetches). Default: false
NEXT_PUBLIC_METADATA_ENABLED=false
## Request timeout (ms). Default: 10000
NEXT_PUBLIC_METADATA_TIMEOUT=
## Max content size (bytes). Default: 1000000
NEXT_PUBLIC_METADATA_MAX_CONTENT_SIZE=
## User-Agent for proxy requests. Default: "Solana Explorer"
NEXT_PUBLIC_METADATA_USER_AGENT="Solana Explorer"

# -----------------------------------------------------------------------------
# Tokens
# -----------------------------------------------------------------------------
## Comma-separated token addresses to redact from the UI
NEXT_PUBLIC_BAD_TOKENS=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
## Max log level: 0=ERROR 1=WARN 2=INFO 3=DEBUG. Unset = logging disabled
NEXT_LOG_LEVEL=0

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
## Google Analytics 4 ID (gtag)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
## Google Tag Manager container ID (takes priority over GA ID)
NEXT_PUBLIC_GOOGLE_TAG_ID=

# -----------------------------------------------------------------------------
# Server-side secrets (never NEXT_PUBLIC_ — do not expose to browser)
# -----------------------------------------------------------------------------
## CoinGecko API key for price data (optional)
COINGECKO_API_KEY=
## validators.app API token for /ping stats (optional)
PING_API_KEY=
