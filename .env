# ==============================================================================
# GridTokenX Explorer — Environment Configuration (localnet)
# ==============================================================================
# See .env.example for the full documented list of every supported variable.

# --- Application ---
NEXT_PUBLIC_URL=http://localhost:3000

# --- Solana RPC (Localnet) ---
NEXT_PUBLIC_SOLANA_RPC_HTTP=http://localhost:8899
NEXT_PUBLIC_SOLANA_RPC_WS=
NEXT_PUBLIC_DEFAULT_CLUSTER=localnet
NEXT_PUBLIC_LOCALNET_RPC_URL=http://localhost:8899

# Public RPC overrides (leave empty to use public endpoints)
NEXT_PUBLIC_MAINNET_RPC_URL=
NEXT_PUBLIC_DEVNET_RPC_URL=
NEXT_PUBLIC_TESTNET_RPC_URL=

# --- GridTokenX Program IDs (Canonical Localnet) ---
NEXT_PUBLIC_REGISTRY_PROGRAM_ID=FcSd5x4X1nzJMKLZC4tMZXnQ1ipLrGsEfeoH8N4mvJX7
NEXT_PUBLIC_TRADING_PROGRAM_ID=CnWDEUhTvSixeLSyViWgAnnu9YouBAYVGcrrFm1s9WcX
NEXT_PUBLIC_TOKEN_PROGRAM_ID=6FZKcVKCLFSNLMxypFJGU4K14xUBnxNW9VAuKGhmqjGX
NEXT_PUBLIC_ORACLE_PROGRAM_ID=64Vgos61STZ8pW9NnHi2iGtXMTQr7NqBoMorK6Zg8RJU
