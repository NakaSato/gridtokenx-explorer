# --- Backend API ---
NEXT_PUBLIC_API_URL=http://gridtokenx-apisix.orb.local:9080

# --- Explorer Configuration ---
NEXT_LOG_LEVEL=0
NEXT_PUBLIC_METADATA_ENABLED=false
NEXT_PUBLIC_METADATA_TIMEOUT=
